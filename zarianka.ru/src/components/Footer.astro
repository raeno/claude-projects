---
---
<footer class="site-foot">
    <!-- Contact CTA -->
    <div class="foot-cta">
        <p class="foot-cta-text">Хотите заказать изделие или задать вопрос?</p>
        <a href="/contact" class="foot-cta-link">Написать</a>
    </div>

    <div class="foot-main">
        <!-- Nav links -->
        <div class="foot-col">
            <h4 class="foot-heading">Разделы</h4>
            <ul class="foot-nav">
                <li><a href="/bio">О мастере</a></li>
                <li><a href="/work">Работы</a></li>
                <li><a href="/news">Новости</a></li>
                <li><a href="/sold">Под заказ</a></li>
            </ul>
        </div>

        <!-- Contact & social -->
        <div class="foot-col">
            <h4 class="foot-heading">Контакты</h4>
            <ul class="foot-nav">
                <li><a href="https://vk.ru/zarianka_pots" target="_blank" rel="noopener noreferrer">ВКонтакте</a></li>
                <li><a href="/contact">Написать</a></li>
            </ul>
        </div>

        <!-- Bird emblem -->
        <div class="foot-col foot-col-bird">
            <svg class="site-foot-bird" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <ellipse cx="50" cy="65" rx="20" ry="16" fill="currentColor" opacity="0.4"/>
                <circle cx="54" cy="38" r="16" fill="currentColor" opacity="0.4"/>
                <path d="M 41 43 C 35 51 34 64 39 72 C 43 78 53 80 60 74 C 67 67 67 56 62 48 C 57 41 46 39 41 43 Z" fill="currentColor" opacity="0.6"/>
                <ellipse cx="52" cy="41" rx="10" ry="11" fill="currentColor" opacity="0.6"/>
                <circle cx="61" cy="31" r="5" fill="currentColor" opacity="0.3"/>
                <path d="M 68 36 L 80 33 L 68 30 Z" fill="currentColor" opacity="0.4"/>
                <path d="M 35 58 Q 27 65 28 74" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.3"/>
                <path d="M 32 70 L 22 84 L 33 79 Z" fill="currentColor" opacity="0.35"/>
                <line x1="43" y1="79" x2="43" y2="87" stroke="currentColor" stroke-width="2" opacity="0.3"/>
                <line x1="56" y1="79" x2="56" y2="87" stroke="currentColor" stroke-width="2" opacity="0.3"/>
            </svg>
        </div>
    </div>

    <div class="foot-bottom">
        <span>&copy; {new Date().getFullYear()} Юлия Якутова · Зарянка</span>
        <span class="foot-bottom-sep">&middot;</span>
        <span>Сделано с любовью к глине</span>
    </div>

    <!-- Back to top -->
    <button class="back-to-top" aria-label="Вернуться наверх" id="back-to-top">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
    </button>
</footer>

<style>
/* Contact CTA above footer */
.foot-cta {
    text-align: center;
    padding: 3rem 2rem 2.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
}

.foot-cta-text {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    color: var(--color-base);
    margin: 0 0 1rem;
    font-weight: 400;
}

.foot-cta-link {
    display: inline-block;
    padding: 0.8rem 2.4rem;
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.5px;
    color: var(--color-btn-text);
    background: var(--color-btn-bg);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.2s ease;
    min-height: 48px;
    line-height: 48px;
    padding: 0 2.4rem;
}

.foot-cta-link:hover {
    background: var(--color-primary);
    text-decoration: none;
    color: var(--color-btn-text);
}

/* Footer grid */
.foot-main {
    display: flex;
    justify-content: center;
    gap: 6rem;
    padding: 1rem 0 2rem;
    flex-wrap: wrap;
}

.foot-col {
    min-width: 120px;
}

.foot-col-bird {
    display: flex;
    align-items: center;
}

.foot-heading {
    font-family: var(--font-sans-serif);
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-base);
    margin: 0 0 0.8rem;
    opacity: 0.7;
}

.foot-nav {
    list-style: none;
    margin: 0;
    padding: 0;
}

.foot-nav li {
    margin: 0.35rem 0;
    padding: 0;
    line-height: 1.4;
}

.foot-nav a {
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 4px 0;
    display: inline-block;
}

.foot-nav a:hover {
    color: var(--color-primary);
    text-decoration: none;
}

.site-foot-bird {
    display: block;
    width: 48px;
    height: 48px;
    opacity: 0.4;
}

/* Bottom bar */
.foot-bottom {
    text-align: center;
    padding: 1.5rem 0 0.5rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-sans-serif);
    font-size: 1.25rem;
    color: var(--color-text-muted);
    font-weight: 300;
}

.foot-bottom-sep {
    margin: 0 0.4rem;
    opacity: 0.4;
}

/* Back to top */
.back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 44px;
    height: 44px;
    min-width: 48px;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, background 0.2s ease, color 0.2s ease;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
}

.back-to-top:hover {
    background: var(--color-btn-bg);
    color: var(--color-btn-text);
    border-color: var(--color-btn-bg);
}

@media (max-width: 700px) {
    .foot-main {
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        text-align: center;
    }
    .foot-cta-text {
        font-size: 1.8rem;
    }
    .back-to-top {
        bottom: 1.2rem;
        right: 1.2rem;
    }
}
</style>
