---
export interface Props {
    image?: string;
    heading?: string;
    subheading?: string;
    ctaText?: string;
    ctaHref?: string;
}

const { image, heading, subheading, ctaText, ctaHref } = Astro.props;
---

<section class="hero">
    {image && (
        <img
            src={image}
            alt={heading || 'Зарянка'}
            class="hero-image"
        />
    )}
    <div class="hero-overlay"></div>
    <div class="hero-content">
        {heading && <h1 class="hero-heading">{heading}</h1>}
        {subheading && <p class="hero-subheading">{subheading}</p>}
        {ctaText && ctaHref && (
            <a href={ctaHref} class="hero-cta">{ctaText}</a>
        )}
    </div>
</section>

<style>
.hero {
    position: relative;
    width: 100%;
    height: 65vh;
    min-height: 400px;
    max-height: 720px;
    overflow: hidden;
    border-radius: 16px;
    margin-bottom: 3rem;
}

.hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
}

.hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
        to bottom,
        rgba(30, 22, 16, 0.1) 0%,
        rgba(30, 22, 16, 0.3) 50%,
        rgba(30, 22, 16, 0.65) 100%
    );
}

.hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 3rem 4rem;
    color: #F5F0E8;
}

.hero-heading {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 5.6rem;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 1px;
}

.hero-subheading {
    margin: 0.6rem 0 0;
    font-family: var(--font-sans-serif);
    font-size: 1.8rem;
    font-weight: 300;
    letter-spacing: 3px;
    text-transform: lowercase;
    opacity: 0.85;
}

.hero-cta {
    display: inline-block;
    margin-top: 1.6rem;
    padding: 0.9rem 2.4rem;
    font-family: var(--font-sans-serif);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 1px;
    color: #F5F0E8;
    border: 1px solid rgba(245, 240, 232, 0.5);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.3s ease, border-color 0.3s ease;
    backdrop-filter: blur(4px);
    background: rgba(245, 240, 232, 0.08);
}

.hero-cta:hover {
    background: rgba(245, 240, 232, 0.18);
    border-color: rgba(245, 240, 232, 0.8);
    text-decoration: none;
}

@media (max-width: 700px) {
    .hero {
        height: 55vh;
        min-height: 300px;
        border-radius: 12px;
    }
    .hero-content {
        padding: 2rem 2.5rem;
    }
    .hero-heading {
        font-size: 3.6rem;
    }
    .hero-subheading {
        font-size: 1.5rem;
        letter-spacing: 2px;
    }
    .hero-cta {
        padding: 0.7rem 1.8rem;
        font-size: 1.4rem;
    }
}
</style>
