---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

// Fetch all collections
const allPages = await getCollection('pages');
const allNews = await getCollection('news');
const allWork = await getCollection('work');
const allSold = await getCollection('sold');

// Combine for filtering
const allContent = [...allPages, ...allNews, ...allWork, ...allSold];

// Filter for pagetype containing 'main' and sort by number
const posts = allContent.filter(item => {
    return item.data.pagetype && item.data.pagetype.includes('main');
}).sort((a, b) => {
    const numA = a.data.number || 9999;
    const numB = b.data.number || 9999;
    return numA - numB;
});

// Get index-page metadata (from pages collection)
const indexPage = allPages.find(p => p.slug === 'index');
const title = indexPage?.data.title || 'Зарянка';
const description = indexPage?.data.description;
const heroImage = indexPage?.data.featuredimage || indexPage?.data.image;
const heading = indexPage?.data.heading || 'Зарянка';
const subheading = indexPage?.data.subheading || 'авторская керамика';

let postCounter = 0;
---

<Layout title={title} description={description}>
    <Hero
        image={heroImage}
        heading={heading}
        subheading={subheading}
        ctaText="Посмотреть работы"
        ctaHref="/work"
    />

    <section class="intro-section fade-in-section">
        <p class="intro-text">
            Авторская керамика ручной работы. Каждое изделие — единственное в своём роде,
            сделано на гончарном круге с натуральными глазурями.
        </p>
    </section>

    <div class="post-feed">
        {posts.map((post) => {
            postCounter++;
            let slug = post.slug;
            if (post.collection === 'work') slug = `work/${post.slug}`;
            if (post.collection === 'news') slug = `news/${post.slug}`;
            if (post.collection === 'sold') slug = `sold/${post.slug}`;

            return (
                <PostCard
                    count={postCounter}
                    post={post}
                    slug={slug}
                />
            );
        })}
    </div>
</Layout>

<style>
.intro-section {
    max-width: 680px;
    margin: 0 auto 3rem;
    text-align: center;
    padding: 0 2rem;
}

.intro-text {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    font-weight: 400;
    margin: 0;
}

@media (max-width: 700px) {
    .intro-text {
        font-size: 1.8rem;
    }
}
</style>
